<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BackgroundColor">#000000</Color>
    <Color x:Key="SurfaceColor">#0A0A0A</Color>
    <Color x:Key="SurfaceElevatedColor">#111111</Color>
    <Color x:Key="SidebarColor">#000000</Color>
    <Color x:Key="BorderColor">#FFFFFF</Color>
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#FFFF00</Color>
    <Color x:Key="TextDisabledColor">#808080</Color>
    <Color x:Key="TextOnAccentColor">#000000</Color>
    <Color x:Key="AccentColor">#00FF00</Color>
    <Color x:Key="AccentHoverColor">#00CC00</Color>
    <Color x:Key="AccentPressedColor">#009900</Color>
    <Color x:Key="SuccessColor">#00FF00</Color>
    <Color x:Key="WarningColor">#FFFF00</Color>
    <Color x:Key="ErrorColor">#FF0000</Color>
    <Color x:Key="InfoColor">#00FFFF</Color>
    <Color x:Key="PriorityNoneColor">#808080</Color>
    <Color x:Key="PriorityLowColor">#00FFFF</Color>
    <Color x:Key="PriorityMediumColor">#FFFF00</Color>
    <Color x:Key="PriorityHighColor">#FF8800</Color>
    <Color x:Key="PriorityCriticalColor">#FF0000</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <!-- Canvas content theming defaults. A canvas document with custom ThemeColors shadows these
         via direct Application.Current.Resources entries (see CanvasThemeService). -->
    <SolidColorBrush x:Key="CanvasTextBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="CanvasAccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="CanvasSurfaceBrush" Color="{StaticResource SurfaceColor}" />

    <!-- Sticky-note (markdown snapshot) chrome. App-theme resources only — deliberately NOT part
         of the per-document Colors dialog (see LightTheme.xaml). -->
    <SolidColorBrush x:Key="StickyNoteBrush" Color="#000000" />
    <SolidColorBrush x:Key="StickyNoteBorderBrush" Color="#FFFF00" />
    <SolidColorBrush x:Key="StickyNoteTextBrush" Color="#FFFFFF" />

    <!-- Code block editor surface -->
    <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="CodeHeaderBrush" Color="#0A0A0A" />
    <SolidColorBrush x:Key="CodeTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CodeMutedBrush" Color="#FFFF00" />

    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#FFFF00" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#000000" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#00FF00" />
    <SolidColorBrush x:Key="KanbanNotStartedBrush" Color="#000000" />
    <SolidColorBrush x:Key="KanbanInProgressBrush" Color="#000000" />
    <SolidColorBrush x:Key="KanbanReviewBrush" Color="#000000" />
    <SolidColorBrush x:Key="KanbanCompletedBrush" Color="#000000" />
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#40FFFFFF" />
    <SolidColorBrush x:Key="SelectedOverlayBrush" Color="#6000FF00" />

    <DropShadowEffect x:Key="CardShadow" Color="#FFFFFF" Direction="270"
                      ShadowDepth="0" BlurRadius="0" Opacity="0" />
    <DropShadowEffect x:Key="PopupShadow" Color="#FFFFFF" Direction="270"
                      ShadowDepth="0" BlurRadius="0" Opacity="0" />

    <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Cascadia Code, Consolas, Courier New</FontFamily>
    <sys:Double x:Key="FontSizeXS" xmlns:sys="clr-namespace:System;assembly=mscorlib">11</sys:Double>
    <sys:Double x:Key="FontSizeSM" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="FontSizeMD" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
    <sys:Double x:Key="FontSizeLG" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="FontSizeXL" xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Double>
    <sys:Double x:Key="FontSizeXXL" xmlns:sys="clr-namespace:System;assembly=mscorlib">26</sys:Double>
    <CornerRadius x:Key="RadiusSM">0</CornerRadius>
    <CornerRadius x:Key="RadiusMD">0</CornerRadius>
    <CornerRadius x:Key="RadiusLG">0</CornerRadius>
    <CornerRadius x:Key="RadiusXL">0</CornerRadius>
    <Thickness x:Key="PaddingXS">4</Thickness>
    <Thickness x:Key="PaddingSM">8</Thickness>
    <Thickness x:Key="PaddingMD">12</Thickness>
    <Thickness x:Key="PaddingLG">16</Thickness>
    <Thickness x:Key="PaddingXL">24</Thickness>

</ResourceDictionary>
