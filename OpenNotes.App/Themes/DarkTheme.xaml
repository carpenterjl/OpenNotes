<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background tones -->
    <Color x:Key="BackgroundColor">#1E1E2E</Color>
    <Color x:Key="SurfaceColor">#2A2A3E</Color>
    <Color x:Key="SurfaceElevatedColor">#313145</Color>
    <Color x:Key="SidebarColor">#181826</Color>
    <Color x:Key="BorderColor">#3D3D5C</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#ECEFF4</Color>
    <Color x:Key="TextSecondaryColor">#A0A8C0</Color>
    <Color x:Key="TextDisabledColor">#5A5E78</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#7B9CDF</Color>
    <Color x:Key="AccentHoverColor">#8FAAEC</Color>
    <Color x:Key="AccentPressedColor">#6A8BD0</Color>

    <!-- Semantic colors -->
    <Color x:Key="SuccessColor">#A3BE8C</Color>
    <Color x:Key="WarningColor">#EBCB8B</Color>
    <Color x:Key="ErrorColor">#BF616A</Color>
    <Color x:Key="InfoColor">#81A1C1</Color>

    <!-- Priority colors -->
    <Color x:Key="PriorityNoneColor">#5A5E78</Color>
    <Color x:Key="PriorityLowColor">#88C0D0</Color>
    <Color x:Key="PriorityMediumColor">#EBCB8B</Color>
    <Color x:Key="PriorityHighColor">#D08770</Color>
    <Color x:Key="PriorityCriticalColor">#BF616A</Color>

    <!-- Brushes derived from colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <!-- Canvas content theming defaults. A canvas document with custom ThemeColors shadows these
         via direct Application.Current.Resources entries (see CanvasThemeService). -->
    <SolidColorBrush x:Key="CanvasTextBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="CanvasAccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="CanvasSurfaceBrush" Color="{StaticResource SurfaceColor}" />

    <!-- Sticky-note (markdown snapshot) chrome. App-theme resources only — deliberately NOT part
         of the per-document Colors dialog (see LightTheme.xaml). Muted olive keeps the "paper"
         read without glowing on the dark canvas. -->
    <SolidColorBrush x:Key="StickyNoteBrush" Color="#4A4529" />
    <SolidColorBrush x:Key="StickyNoteBorderBrush" Color="#6B6335" />
    <SolidColorBrush x:Key="StickyNoteTextBrush" Color="#EDE7C9" />

    <!-- Code block editor surface -->
    <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#1A1A2A" />
    <SolidColorBrush x:Key="CodeHeaderBrush" Color="#12121E" />
    <SolidColorBrush x:Key="CodeTextBrush" Color="#D4D4D4" />
    <SolidColorBrush x:Key="CodeMutedBrush" Color="#A0A0C0" />

    <!-- Scrollbar thumb -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#4A4A6A" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#6A6A8A" />

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#252538" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#3D3D5C" />
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="{StaticResource AccentColor}" />

    <!-- Kanban columns -->
    <SolidColorBrush x:Key="KanbanNotStartedBrush" Color="#2A2A3E" />
    <SolidColorBrush x:Key="KanbanInProgressBrush" Color="#1E2E3E" />
    <SolidColorBrush x:Key="KanbanReviewBrush" Color="#2E2A1E" />
    <SolidColorBrush x:Key="KanbanCompletedBrush" Color="#1E2E1E" />

    <!-- Hover/selected state overlays -->
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#20FFFFFF" />
    <SolidColorBrush x:Key="SelectedOverlayBrush" Color="#307B9CDF" />

    <!-- Shadows -->
    <DropShadowEffect x:Key="CardShadow" Color="#000000" Direction="270"
                      ShadowDepth="2" BlurRadius="8" Opacity="0.4" />
    <DropShadowEffect x:Key="PopupShadow" Color="#000000" Direction="270"
                      ShadowDepth="4" BlurRadius="16" Opacity="0.6" />

    <!-- Typography -->
    <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Cascadia Code, Consolas, Courier New</FontFamily>
    <sys:Double x:Key="FontSizeXS" xmlns:sys="clr-namespace:System;assembly=mscorlib">11</sys:Double>
    <sys:Double x:Key="FontSizeSM" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="FontSizeMD" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
    <sys:Double x:Key="FontSizeLG" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>
    <sys:Double x:Key="FontSizeXL" xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Double>
    <sys:Double x:Key="FontSizeXXL" xmlns:sys="clr-namespace:System;assembly=mscorlib">26</sys:Double>

    <!-- Corner radii -->
    <CornerRadius x:Key="RadiusSM">4</CornerRadius>
    <CornerRadius x:Key="RadiusMD">8</CornerRadius>
    <CornerRadius x:Key="RadiusLG">12</CornerRadius>
    <CornerRadius x:Key="RadiusXL">16</CornerRadius>

    <!-- Spacing -->
    <Thickness x:Key="PaddingXS">4</Thickness>
    <Thickness x:Key="PaddingSM">8</Thickness>
    <Thickness x:Key="PaddingMD">12</Thickness>
    <Thickness x:Key="PaddingLG">16</Thickness>
    <Thickness x:Key="PaddingXL">24</Thickness>

</ResourceDictionary>
