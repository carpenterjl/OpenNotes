<Window x:Class="OpenNotes.Dialogs.CanvasSizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Canvas Page Size" Width="420" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStyle="ToolWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose a preset or enter a custom size (pixels):"
                   FontSize="{DynamicResource FontSizeMD}"
                   Foreground="{DynamicResource TextPrimaryBrush}" />

        <ComboBox Grid.Row="2" x:Name="PresetCombo"
                  SelectionChanged="PresetCombo_SelectionChanged"
                  FontSize="{DynamicResource FontSizeSM}">
            <ComboBoxItem Content="Custom" Tag="Custom" />
            <ComboBoxItem Content="Letter (850 × 1100)" Tag="850,1100" />
            <ComboBoxItem Content="Legal (850 × 1400)" Tag="850,1400" />
            <ComboBoxItem Content="Tabloid (1056 × 1632)" Tag="1056,1632" />
            <ComboBoxItem Content="A4 (794 × 1123)" Tag="794,1123" />
            <ComboBoxItem Content="A3 (1123 × 1587)" Tag="1123,1587" />
            <ComboBoxItem Content="Widescreen (1920 × 1080)" Tag="1920,1080" />
            <ComboBoxItem Content="Large Canvas (3000 × 2000)" Tag="3000,2000" />
        </ComboBox>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Width (px)" FontSize="{DynamicResource FontSizeSM}"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox x:Name="WidthBox" Style="{StaticResource ModernTextBox}"
                         TextChanged="SizeBox_TextChanged" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Height (px)" FontSize="{DynamicResource FontSizeSM}"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox x:Name="HeightBox" Style="{StaticResource ModernTextBox}"
                         TextChanged="SizeBox_TextChanged" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="72" Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButton}"
                    Click="Cancel_Click" />
            <Button Content="OK" Width="72"
                    Style="{DynamicResource PrimaryButton}"
                    IsDefault="True"
                    Click="OK_Click" />
        </StackPanel>
    </Grid>
</Window>
