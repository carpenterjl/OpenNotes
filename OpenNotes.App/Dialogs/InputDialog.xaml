<Window x:Class="OpenNotes.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="160" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStyle="ToolWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="PromptText"
                   FontSize="{DynamicResource FontSizeMD}"
                   Foreground="{DynamicResource TextPrimaryBrush}" />

        <TextBox Grid.Row="2" x:Name="InputTextBox"
                 Style="{DynamicResource ModernTextBox}"
                 KeyDown="InputTextBox_KeyDown" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="72" Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButton}"
                    Click="Cancel_Click" />
            <Button Content="OK" Width="72"
                    Style="{DynamicResource PrimaryButton}"
                    IsDefault="True"
                    Click="OK_Click" />
        </StackPanel>
    </Grid>
</Window>
