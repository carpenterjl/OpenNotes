<Window x:Class="OpenNotes.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="560" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <TextBlock Text="Settings"
                       FontSize="{DynamicResource FontSizeXL}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="24,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Theme -->
                <TextBlock Text="APPEARANCE"
                           FontSize="{DynamicResource FontSizeXS}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,8" />

                <DockPanel Margin="0,0,0,16">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Theme"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <ComboBox DockPanel.Dock="Right"
                              x:Name="ThemeCombo"
                              MinWidth="150"
                              HorizontalAlignment="Right"
                              FontSize="{DynamicResource FontSizeSM}">
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="High Contrast" Tag="HighContrast" />
                        <ComboBoxItem Content="Custom" Tag="Custom" />
                    </ComboBox>
                </DockPanel>

                <DockPanel Margin="0,0,0,16">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Custom colors"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right"
                            Content="Customize Colors…"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,4"
                            HorizontalAlignment="Right"
                            Click="Customize_Click" />
                </DockPanel>

                <Separator Margin="0,8" Background="{DynamicResource BorderBrush}" />

                <!-- Autosave -->
                <TextBlock Text="AUTOSAVE"
                           FontSize="{DynamicResource FontSizeXS}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,8,0,8" />

                <DockPanel Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Autosave interval (seconds)"
                               FontSize="{DynamicResource FontSizeMD}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBox DockPanel.Dock="Right"
                             x:Name="AutosaveIntervalBox"
                             Text="30"
                             Style="{StaticResource ModernTextBox}"
                             Width="80"
                             HorizontalAlignment="Right"
                             HorizontalContentAlignment="Center" />
                </DockPanel>

                <Separator Margin="0,8" Background="{DynamicResource BorderBrush}" />

                <!-- About -->
                <TextBlock Text="ABOUT"
                           FontSize="{DynamicResource FontSizeXS}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,8,0,8" />

                <StackPanel>
                    <TextBlock Text="OpenNotes v1.0"
                               FontSize="{DynamicResource FontSizeMD}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="A powerful productivity suite built with .NET 8 WPF"
                               FontSize="{DynamicResource FontSizeSM}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Padding="16,6"
                        Margin="0,0,8,0"
                        IsCancel="True" />
                <Button Content="Save"
                        Style="{StaticResource PrimaryButton}"
                        Padding="16,6"
                        IsDefault="True"
                        Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
