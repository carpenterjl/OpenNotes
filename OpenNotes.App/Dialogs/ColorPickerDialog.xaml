<Window x:Class="OpenNotes.Dialogs.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose a Color" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStyle="ToolWindow">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top: SV square | hue bar | channel controls -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="22" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <!-- Saturation / Brightness square -->
            <Border Grid.Column="0" BorderThickness="1" CornerRadius="3"
                    BorderBrush="{DynamicResource BorderBrush}">
                <Canvas x:Name="SvCanvas" Width="220" Height="220" ClipToBounds="True"
                        Background="Transparent"
                        MouseLeftButtonDown="SvCanvas_MouseDown"
                        MouseMove="SvCanvas_MouseMove"
                        MouseLeftButtonUp="SvCanvas_MouseUp">
                    <!-- base hue → white (horizontal saturation) -->
                    <Rectangle x:Name="SatRect" Width="220" Height="220" IsHitTestVisible="False" />
                    <!-- transparent → black (vertical value) -->
                    <Rectangle Width="220" Height="220" IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#00000000" />
                                <GradientStop Offset="1" Color="#FF000000" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Ellipse x:Name="SvThumb" Width="14" Height="14" IsHitTestVisible="False"
                             Stroke="White" StrokeThickness="2" Fill="#40000000" />
                </Canvas>
            </Border>

            <!-- Hue bar -->
            <Border Grid.Column="2" BorderThickness="1" CornerRadius="3"
                    BorderBrush="{DynamicResource BorderBrush}">
                <Canvas x:Name="HueCanvas" Width="24" Height="220" ClipToBounds="True"
                        Background="Transparent"
                        MouseLeftButtonDown="HueCanvas_MouseDown"
                        MouseMove="HueCanvas_MouseMove"
                        MouseLeftButtonUp="HueCanvas_MouseUp">
                    <Rectangle Width="24" Height="220" IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.000" Color="#FF0000" />
                                <GradientStop Offset="0.167" Color="#FFFF00" />
                                <GradientStop Offset="0.333" Color="#00FF00" />
                                <GradientStop Offset="0.500" Color="#00FFFF" />
                                <GradientStop Offset="0.667" Color="#0000FF" />
                                <GradientStop Offset="0.833" Color="#FF00FF" />
                                <GradientStop Offset="1.000" Color="#FF0000" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Border x:Name="HueThumb" Width="28" Height="4" Canvas.Left="-2"
                            IsHitTestVisible="False" CornerRadius="2"
                            Background="Transparent" BorderThickness="2" BorderBrush="White" />
                </Canvas>
            </Border>

            <!-- Channels: preview, hex, RGB sliders -->
            <StackPanel Grid.Column="4" VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="40" CornerRadius="4" BorderThickness="1"
                            BorderBrush="{DynamicResource BorderBrush}">
                        <Border x:Name="PreviewSwatch" CornerRadius="3" />
                    </Border>
                    <TextBox Grid.Column="2" x:Name="HexBox" Width="100" VerticalContentAlignment="Center"
                             Style="{StaticResource ModernTextBox}"
                             TextChanged="HexBox_TextChanged"
                             ToolTip="Hex color, e.g. #7B9CDF" />
                </Grid>

                <TextBlock Text="Red" Margin="0,14,0,0"
                           FontSize="{DynamicResource FontSizeSM}"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" x:Name="RSlider" Minimum="0" Maximum="255"
                            VerticalAlignment="Center" ValueChanged="RgbSlider_ValueChanged" />
                    <TextBlock Grid.Column="1" x:Name="RVal" TextAlignment="Right" VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeSM}" />
                </Grid>

                <TextBlock Text="Green" Margin="0,8,0,0"
                           FontSize="{DynamicResource FontSizeSM}"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" x:Name="GSlider" Minimum="0" Maximum="255"
                            VerticalAlignment="Center" ValueChanged="RgbSlider_ValueChanged" />
                    <TextBlock Grid.Column="1" x:Name="GVal" TextAlignment="Right" VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeSM}" />
                </Grid>

                <TextBlock Text="Blue" Margin="0,8,0,0"
                           FontSize="{DynamicResource FontSizeSM}"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" x:Name="BSlider" Minimum="0" Maximum="255"
                            VerticalAlignment="Center" ValueChanged="RgbSlider_ValueChanged" />
                    <TextBlock Grid.Column="1" x:Name="BVal" TextAlignment="Right" VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeSM}" />
                </Grid>

                <TextBlock Text="Presets" Margin="0,14,0,4"
                           FontSize="{DynamicResource FontSizeSM}"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <WrapPanel x:Name="PresetPanel" />
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button DockPanel.Dock="Right" Content="OK" Width="72"
                    Style="{DynamicResource PrimaryButton}"
                    IsDefault="True" Click="OK_Click" />
            <Button DockPanel.Dock="Right" Content="Cancel" Width="72" Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButton}"
                    IsCancel="True" Click="Cancel_Click" />
        </DockPanel>
    </Grid>
</Window>
