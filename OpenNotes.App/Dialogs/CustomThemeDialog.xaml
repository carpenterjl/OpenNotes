<Window x:Class="OpenNotes.Dialogs.CustomThemeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Theme Colors" Width="460" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStyle="ToolWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap"
                   Text="Set each color for the Custom theme. Values are hex (e.g. #7B9CDF). Fields are seeded from your current theme; OK applies and switches to the Custom theme."
                   FontSize="{DynamicResource FontSizeSM}"
                   Foreground="{DynamicResource TextSecondaryBrush}" />

        <!-- One row per editable brush slot: label | hex box | live preview swatch -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ColorItems">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,6,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                       FontSize="{DynamicResource FontSizeSM}"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBox Grid.Column="1" Text="{Binding Hex, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     ToolTip="Hex color, e.g. #7B9CDF" />
                            <Border Grid.Column="2" Width="24" Height="24" Margin="10,0,0,0"
                                    CornerRadius="4" BorderThickness="1"
                                    Background="{Binding Swatch}"
                                    BorderBrush="{DynamicResource BorderBrush}" HorizontalAlignment="Left"
                                    Cursor="Hand" ToolTip="Click to pick a color"
                                    MouseLeftButtonUp="Swatch_Click" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="Reset to base" Padding="10,4"
                    Style="{DynamicResource SecondaryButton}"
                    ToolTip="Clear all custom colors and revert to the Custom theme's base palette"
                    Click="Reset_Click" />
            <Button DockPanel.Dock="Left" Content="Save…" Padding="10,4" Margin="8,0,0,0"
                    Style="{DynamicResource SecondaryButton}"
                    ToolTip="Save these colors to a theme file"
                    Click="Save_Click" />
            <Button DockPanel.Dock="Left" Content="Load…" Padding="10,4" Margin="8,0,0,0"
                    Style="{DynamicResource SecondaryButton}"
                    ToolTip="Load colors from a theme file"
                    Click="Load_Click" />
            <Button DockPanel.Dock="Right" Content="OK" Width="72"
                    Style="{DynamicResource PrimaryButton}"
                    IsDefault="True"
                    Click="OK_Click" />
            <Button DockPanel.Dock="Right" Content="Cancel" Width="72" Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButton}"
                    IsCancel="True"
                    Click="Cancel_Click" />
        </DockPanel>
    </Grid>
</Window>
