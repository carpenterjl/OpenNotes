<Window x:Class="OpenNotes.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OpenNotes.ViewModels"
        xmlns:views="clr-namespace:OpenNotes.Views"
        xmlns:conv="clr-namespace:OpenNotes.Converters"
        Title="OpenNotes"
        Height="860" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Window.Resources>
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:BoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter" Invert="True" />
        <conv:StringToColorConverter x:Key="StringToColorConverter" />
        <conv:StringToBrushConverter x:Key="StringToBrushConverter" />
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter" />
        <conv:PriorityToBrushConverter x:Key="PriorityToBrushConverter" />

        <!-- DataTemplate routing: ContentPresenter picks template by ViewModel type -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskListViewModel}">
            <views:TaskListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskEditorViewModel}">
            <views:TaskEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:KanbanViewModel}">
            <views:KanbanView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CanvasEditorViewModel}">
            <views:CanvasEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CanvasLibraryViewModel}">
            <views:CanvasLibraryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SearchViewModel}">
            <views:SearchView />
        </DataTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding OpenCommandPaletteCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding RedoCommand}" />
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding NavigateToDashboardCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Toolbar -->
            <RowDefinition Height="*" />
            <!-- Content -->
            <RowDefinition Height="Auto" />
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <DockPanel>
                <!-- Left buttons -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip="Toggle Sidebar (Ctrl+B)"
                            Content="☰"
                            FontSize="16" />
                    <Separator Width="1" Margin="4,0" Background="{DynamicResource BorderBrush}" />
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding UndoCommand}"
                            IsEnabled="{Binding CanUndo}"
                            ToolTip="{Binding NextUndoDescription, StringFormat='Undo: {0}'}"
                            Content="↩" FontSize="14" />
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding RedoCommand}"
                            IsEnabled="{Binding CanRedo}"
                            ToolTip="Redo"
                            Content="↪" FontSize="14" />
                </StackPanel>

                <!-- Center: workspace name -->
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding ActiveWorkspace.Name}"
                           FontSize="{DynamicResource FontSizeMD}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="16,0" />

                <!-- Right buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenCommandPaletteCommand}"
                            ToolTip="Command Palette (Ctrl+P)"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌘  " />
                            <TextBlock Text="Command Palette" />
                            <TextBlock Text="  Ctrl+P" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="{DynamicResource FontSizeXS}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Margin="8,0" Background="{DynamicResource BorderBrush}" />

                    <!-- Theme toggle -->
                    <Button Style="{StaticResource IconButton}"
                            ToolTip="Switch Theme"
                            Tag="{Binding}">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Dark" Command="{Binding SwitchThemeCommand}" CommandParameter="Dark" />
                                <MenuItem Header="Light" Command="{Binding SwitchThemeCommand}" CommandParameter="Light" />
                                <MenuItem Header="High Contrast" Command="{Binding SwitchThemeCommand}" CommandParameter="HighContrast" />
                            </ContextMenu>
                        </Button.ContextMenu>
                        <TextBlock Text="🎨" FontSize="14" />
                    </Button>

                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding OpenSettingsCommand}"
                            ToolTip="Settings"
                            Content="⚙" FontSize="14" />
                </StackPanel>

                <Grid />
            </DockPanel>
        </Border>

        <!-- ===== Main Content ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="240"
                                  MinWidth="180" MaxWidth="360">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarVisible}" Value="False">
                                    <Setter Property="Width" Value="0" />
                                    <Setter Property="MinWidth" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>

                <!-- Splitter -->
                <ColumnDefinition Width="1" />

                <!-- Content Area -->
                <ColumnDefinition Width="*" />

                <!-- Inspector Splitter -->
                <ColumnDefinition Width="1" />

                <!-- Inspector panel (future) -->
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <views:SidebarView Grid.Column="0"
                               DataContext="{Binding SidebarViewModel}"
                               Visibility="{Binding DataContext.IsSidebarVisible,
                                             RelativeSource={RelativeSource AncestorType=Window},
                                             Converter={StaticResource BoolToVisibilityConverter}}" />

            <GridSplitter Grid.Column="1" Width="1"
                          Background="{DynamicResource BorderBrush}"
                          ResizeBehavior="PreviousAndNext"
                          HorizontalAlignment="Stretch" />

            <!-- Active Content View -->
            <ContentPresenter Grid.Column="2"
                              Content="{Binding ActiveContent}" />
        </Grid>

        <!-- ===== Status Bar ===== -->
        <Border Grid.Row="2"
                Background="{DynamicResource AccentBrush}"
                Padding="12,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding StatusMessage}"
                           FontSize="{DynamicResource FontSizeXS}"
                           Foreground="{DynamicResource TextOnAccentBrush}"
                           VerticalAlignment="Center" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding CurrentTheme, StringFormat='Theme: {0}'}"
                               FontSize="{DynamicResource FontSizeXS}"
                               Foreground="{DynamicResource TextOnAccentBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Grid />
            </DockPanel>
        </Border>

        <!-- Command Palette Overlay -->
        <Grid Grid.Row="1"
              x:Name="CommandPaletteOverlay"
              Visibility="{Binding IsCommandPaletteOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              IsVisibleChanged="CommandPaletteOverlay_IsVisibleChanged"
              Background="#80000000"
              Panel.ZIndex="100">
            <Border DataContext="{Binding Palette}"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource RadiusLG}"
                    Effect="{DynamicResource PopupShadow}"
                    Width="620" MaxHeight="520"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    Margin="0,60,0,0"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Search / token input row -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <!-- Guided-argument header: command title + token chips -->
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,8"
                                        Visibility="{Binding IsArgMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding ActiveCommandTitle}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="›" Margin="6,0" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                <ItemsControl ItemsSource="{Binding ArgChips}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="2,0" Padding="8,3" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <!-- Pending (default): faint outline -->
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="Filled">
                                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="Current">
                                                                <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                                <Setter Property="BorderThickness" Value="1.5" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Text}" FontSize="{DynamicResource FontSizeSM}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="Filled">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="Current">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <TextBox x:Name="CommandSearchBox"
                                     Style="{StaticResource ModernTextBox}"
                                     FontSize="{DynamicResource FontSizeLG}"
                                     Tag="{Binding InputPlaceholder}"
                                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     PreviewKeyDown="CommandSearchBox_PreviewKeyDown" />
                        </StackPanel>
                    </Border>

                    <!-- Results dropdown -->
                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding Rows}"
                                 SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="4,1" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.AcceptRowCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Description}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="12,8"
                                            Cursor="Hand"
                                            HorizontalContentAlignment="Stretch">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Display}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="{DynamicResource FontSizeMD}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Hint}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="{DynamicResource FontSizeSM}"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Padding="6,2" CornerRadius="3" Margin="6,0,0,0"
                                                        Background="{DynamicResource BackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Shortcut}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Shortcut}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Shortcut}"
                                                               FontSize="{DynamicResource FontSizeXS}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Border>
                                                <TextBlock Text="{Binding Category}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="{DynamicResource FontSizeXS}"
                                                           Margin="10,0,2,0"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="No matching commands"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="16"
                                   Visibility="{Binding Rows.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Invert}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
