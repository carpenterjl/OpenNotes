<UserControl x:Class="OpenNotes.Views.KanbanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OpenNotes.Converters"
             xmlns:vm="clr-namespace:OpenNotes.ViewModels"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrush" />
        <conv:PriorityToBrushConverter x:Key="PriorityToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <TextBlock Text="Kanban Board"
                       FontSize="{DynamicResource FontSizeXL}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
        </Border>

        <!-- Board -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Columns}"
                          Margin="16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:KanbanColumn}">
                        <Border Width="280"
                                Margin="0,0,12,0"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource RadiusMD}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Column header -->
                                <Border Grid.Row="0"
                                        Background="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                        CornerRadius="6,6,0,0"
                                        Padding="12,10">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Tasks.Count, StringFormat='({0})'}"
                                                   FontSize="{DynamicResource FontSizeXS}"
                                                   Foreground="#CCFFFFFF"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Header}"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   FontSize="{DynamicResource FontSizeSM}" />
                                    </DockPanel>
                                </Border>

                                <!-- Cards -->
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="600">
                                    <ItemsControl ItemsSource="{Binding Tasks}"
                                                  Margin="8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,6"
                                                        Background="{DynamicResource BackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource RadiusSM}"
                                                        Padding="10,8"
                                                        Cursor="Hand"
                                                        MouseLeftButtonUp="TaskCard_Click"
                                                        Tag="{Binding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Priority stripe -->
                                                        <Rectangle Grid.Column="0"
                                                                   Width="3" Height="28"
                                                                   RadiusX="1.5" RadiusY="1.5"
                                                                   Margin="0,0,8,0"
                                                                   Fill="{Binding Priority, Converter={StaticResource PriorityToBrush}}" />

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="{DynamicResource FontSizeSM}"
                                                                       FontWeight="Medium"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding DueDate, StringFormat='Due {0:MMM d}'}"
                                                                       FontSize="{DynamicResource FontSizeXS}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Add card button -->
                                <Button Grid.Row="2"
                                        Content="+ Add task"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="8"
                                        Padding="8,4"
                                        FontSize="{DynamicResource FontSizeXS}"
                                        Command="{Binding DataContext.CreateTaskInColumnCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
