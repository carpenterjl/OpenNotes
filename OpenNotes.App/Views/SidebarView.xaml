<UserControl x:Class="OpenNotes.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OpenNotes.ViewModels"
             xmlns:conv="clr-namespace:OpenNotes.Converters"
             Background="{DynamicResource SidebarBrush}"
             MinWidth="200" MaxWidth="320">

    <UserControl.Resources>
        <conv:StringToColorConverter x:Key="StringToColorConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,16,12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="OpenNotes"
                           FontSize="{DynamicResource FontSizeXL}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,0,8" />
            </StackPanel>
        </Border>

        <!-- Navigation Tree -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="8">
            <StackPanel>

                <!-- Navigation Links -->
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="VIEWS"
                               FontSize="{DynamicResource FontSizeXS}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="4,0,4,4" />

                    <Button Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left"
                            Padding="8,6"
                            Command="{Binding DataContext.NavigateToDashboardCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                            Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊡  " />
                            <TextBlock Text="Dashboard" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left"
                            Padding="8,6"
                            Command="{Binding NavigateToTasksCommand}"
                            Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☑  " />
                            <TextBlock Text="Tasks" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left"
                            Padding="8,6"
                            Command="{Binding NavigateToKanbanCommand}"
                            Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬜  " />
                            <TextBlock Text="Kanban" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left"
                            Padding="8,6"
                            Command="{Binding NavigateToCanvasesCommand}"
                            Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎨  " />
                            <TextBlock Text="Canvases" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButton}"
                            HorizontalContentAlignment="Left"
                            Padding="8,6"
                            Command="{Binding NavigateToSearchCommand}"
                            Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍  " />
                            <TextBlock Text="Search" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Separator Style="{StaticResource ThinSeparator}" Margin="4,12" />

                <!-- Workspaces Section -->
                <StackPanel>
                    <DockPanel Margin="4,0,4,4">
                        <TextBlock Text="WORKSPACES"
                                   FontSize="{DynamicResource FontSizeXS}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right"
                                Content="+"
                                Style="{StaticResource IconButton}"
                                Width="22" Height="22"
                                FontSize="16"
                                Command="{Binding CreateWorkspaceCommand}"
                                ToolTip="New Workspace" />
                    </DockPanel>

                    <ListBox ItemsSource="{Binding Workspaces}"
                             SelectedItem="{Binding SelectedWorkspace}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SidebarListBoxItem}">
                                <EventSetter Event="MouseDoubleClick" Handler="WorkspaceItem_DoubleClick" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Color Dot -->
                                    <Ellipse Grid.Column="0" Width="10" Height="10"
                                             Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding ColorHex, Converter={StaticResource StringToColorConverter}}" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="{DynamicResource FontSizeMD}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TotalTaskCount}"
                                               FontSize="{DynamicResource FontSizeXS}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="12,8"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock FontSize="{DynamicResource FontSizeXS}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="OpenNotes v1.0" />
        </Border>
    </Grid>
</UserControl>
