<UserControl x:Class="OpenNotes.Views.Blocks.ChecklistBlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ItemsControl Grid.Row="0" ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />

                        <TextBox Grid.Column="1"
                                 Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center"
                                 FontSize="{DynamicResource FontSizeMD}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Padding="4,2"
                                 PreviewMouseLeftButtonDown="ItemTextBox_PreviewMouseLeftButtonDown" />

                        <Button Grid.Column="2"
                                Content="✕"
                                Style="{StaticResource IconButton}"
                                FontSize="10"
                                Command="{Binding DataContext.RemoveItemCommand,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Foreground="{DynamicResource TextSecondaryBrush}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Grid.Row="1"
                Content="+ Add item"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Left"
                Padding="8,4"
                FontSize="{DynamicResource FontSizeXS}"
                Margin="0,6,0,0"
                Command="{Binding AddItemCommand}" />
    </Grid>
</UserControl>
