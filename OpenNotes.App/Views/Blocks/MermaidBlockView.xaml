<UserControl x:Class="OpenNotes.Views.Blocks.MermaidBlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OpenNotes.Converters"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <!-- The preview row is star-sized so dragging the block's resize grip (which sets the
         block's EditorHeight) grows the WebView2 area; MinHeight keeps the default look when
         the block still auto-sizes. The rendered diagram re-fits itself on every viewport
         resize via the fit script in MermaidHtmlBuilder. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="200" />
        </Grid.RowDefinitions>

        <!-- Definition editor -->
        <TextBox Grid.Row="0"
                 Text="{Binding Definition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource ModernTextBox}"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 MinHeight="80"
                 FontFamily="Consolas,Courier New"
                 FontSize="{DynamicResource FontSizeSM}"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 Tag="Mermaid diagram definition..." />

        <!-- Render button + error -->
        <DockPanel Grid.Row="1" Margin="0,4,0,4">
            <Button DockPanel.Dock="Left"
                    Content="Render"
                    Style="{StaticResource SecondaryButton}"
                    Padding="8,2"
                    FontSize="{DynamicResource FontSizeXS}"
                    x:Name="RenderButton" />
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource PriorityHighBrush}"
                       FontSize="{DynamicResource FontSizeXS}"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}" />
        </DockPanel>

        <!-- WebView2 preview. WebView2CompositionControl (not WebView2): the HWND-hosted control
             ignores WPF z-order/clipping ("airspace") and paints over the action bar and other
             chrome while the task scrolls; the composition control renders into the WPF visual
             tree and scrolls/clips like any other element. -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource RadiusSM}">
            <wv2:WebView2CompositionControl x:Name="MermaidWebView" />
        </Border>
    </Grid>
</UserControl>
