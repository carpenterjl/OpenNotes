<UserControl x:Class="OpenNotes.Views.Blocks.CodeBlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit">

    <Border Background="{DynamicResource CodeBackgroundBrush}"
            CornerRadius="{DynamicResource RadiusSM}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CodeHeaderBrush}"
                    Padding="10,6"
                    CornerRadius="4,4,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding Language}"
                               Foreground="{DynamicResource CodeMutedBrush}"
                               FontSize="{DynamicResource FontSizeXS}"
                               FontFamily="Consolas"
                               VerticalAlignment="Center" />
                    <ComboBox DockPanel.Dock="Right"
                              ItemsSource="{Binding SupportedLanguages}"
                              SelectedItem="{Binding Language, Mode=TwoWay}"
                              Background="Transparent"
                              Foreground="{DynamicResource CodeMutedBrush}"
                              BorderThickness="0"
                              FontSize="{DynamicResource FontSizeXS}"
                              Width="120"
                              HorizontalAlignment="Right" />
                </DockPanel>
            </Border>

            <!-- AvalonEdit -->
            <avalon:TextEditor Grid.Row="1"
                               x:Name="Editor"
                               Foreground="{DynamicResource CodeTextBrush}"
                               Background="Transparent"
                               FontFamily="Consolas,Courier New"
                               FontSize="13"
                               ShowLineNumbers="{Binding ShowLineNumbers}"
                               Padding="8"
                               MinHeight="80"
                               BorderThickness="0"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto" />
        </Grid>
    </Border>
</UserControl>
