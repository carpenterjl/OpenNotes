<UserControl x:Class="OpenNotes.Views.Blocks.LatexBlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OpenNotes.Converters"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="80" />
        </Grid.RowDefinitions>

        <!-- Formula input -->
        <TextBox Grid.Row="0"
                 Text="{Binding Formula, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource ModernTextBox}"
                 FontFamily="Consolas,Courier New"
                 FontSize="{DynamicResource FontSizeSM}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 MaxHeight="220"
                 SpellCheck.IsEnabled="False"
                 Tag="LaTeX formula e.g. \boxed{E = mc^2} (full KaTeX support: \mathbf, \mathbb, aligned, …)" />

        <!-- Error message -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource PriorityHighBrush}"
                   FontSize="{DynamicResource FontSizeXS}"
                   Margin="0,4"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}" />

        <!-- KaTeX preview. WebView2CompositionControl (not WebView2): the HWND-hosted control
             ignores WPF z-order/clipping ("airspace"); the composition control renders into the
             WPF visual tree and scrolls/clips like any other element. It shares the DEFAULT
             WebView2 environment with the Mermaid preview (composition controls coexist there;
             only the classic windowed control must live in its own user-data folder). -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource RadiusSM}"
                Margin="0,6,0,0">
            <wv2:WebView2CompositionControl x:Name="LatexWebView" />
        </Border>
    </Grid>
</UserControl>
