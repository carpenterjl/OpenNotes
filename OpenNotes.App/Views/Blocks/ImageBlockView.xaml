<UserControl x:Class="OpenNotes.Views.Blocks.ImageBlockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Path bar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <Button DockPanel.Dock="Right"
                    Content="Browse..."
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding BrowseImageCommand}"
                    Padding="8,4"
                    Margin="6,0,0,0" />
            <TextBox Text="{Binding FilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ModernTextBox}"
                     Tag="Image file path..."
                     IsReadOnly="True" />
        </DockPanel>

        <!-- Image display -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="{DynamicResource RadiusSM}"
                MinHeight="100"
                MaxHeight="500">
            <Image x:Name="PreviewImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="8"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>

        <!-- Caption -->
        <TextBox Grid.Row="2"
                 Text="{Binding Caption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource ModernTextBox}"
                 Tag="Caption (optional)..."
                 Margin="0,6,0,0"
                 HorizontalAlignment="Center"
                 MaxWidth="400"
                 FontSize="{DynamicResource FontSizeXS}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextAlignment="Center" />
    </Grid>
</UserControl>
